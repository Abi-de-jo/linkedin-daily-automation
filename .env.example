# Required: LinkedIn API access token (OAuth 2.0)
# Get this by running the LinkedIn MCP server's auth flow locally,
# then copy from ~/.linkedin-mcp-token.json -> access_token
LINKEDIN_ACCESS_TOKEN=

# Required: Your LinkedIn Person URN
# Get this from: linkedin_get_profile -> person_urn
LINKEDIN_PERSON_URN=urn:li:person:RLnMVkx9Rc

# Optional: Override the default content topic/angle
# CONTENT_THEME=ai-tools
